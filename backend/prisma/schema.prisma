generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  role      UserRole @default(member)
  plan      Plan     @default(free)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projects      Project[]
  notifications Notification[]
  apiKeys       ApiKey[]

  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  url         String
  description String?
  status      ProjectStatus @default(active)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  agents     Agent[]
  content    ContentPiece[]
  workflows  Workflow[]
  seoAudits  SEOAudit[]
  keywords   Keyword[]
  analytics  AnalyticsData[]
  socialData SocialMonitor[]

  @@map("projects")
}

model Agent {
  id          String       @id @default(cuid())
  name        String
  type        AgentType
  status      AgentStatus  @default(idle)
  description String
  icon        String       @default("Sparkles")
  lastRun     DateTime?    @map("last_run")
  nextRun     DateTime?    @map("next_run")
  frequency   Frequency    @default(manual)
  config      Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  results  AgentResult[]
  metrics  AgentMetrics?
  workflow WorkflowAgent[]

  @@map("agents")
}

model AgentResult {
  id        String           @id @default(cuid())
  timestamp DateTime         @default(now())
  type      String
  data      Json
  status    AgentResultStatus @default(success)

  agentId String @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_results")
}

model AgentMetrics {
  id                String @id @default(cuid())
  tasksCompleted    Int    @default(0) @map("tasks_completed")
  successRate       Float  @default(100) @map("success_rate")
  avgExecutionTime  Int    @default(0) @map("avg_execution_time")
  impactScore       Int    @default(0) @map("impact_score")

  agentId String @unique @map("agent_id")
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_metrics")
}

model SEOAudit {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  overallScore  Int      @map("overall_score")
  categories    Json
  issues        Json
  recommendations Json
  competitors   Json

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("seo_audits")
}

model ContentPiece {
  id               String        @id @default(cuid())
  title            String
  type             ContentType
  status           ContentStatus @default(draft)
  content          String        @db.Text
  seoScore         Int?          @map("seo_score")
  readabilityScore Int?          @map("readability_score")
  keywords         String[]
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  publishedAt      DateTime?     @map("published_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  engagement ContentEngagement?

  @@map("content_pieces")
}

model ContentEngagement {
  id              String @id @default(cuid())
  views           Int    @default(0)
  clicks          Int    @default(0)
  shares          Int    @default(0)
  comments        Int    @default(0)
  avgTimeOnPage   Int    @default(0) @map("avg_time_on_page")

  contentId String       @unique @map("content_id")
  content   ContentPiece @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_engagement")
}

model SocialMonitor {
  id        String   @id @default(cuid())
  platform  String
  keywords  String[]
  mentions  Json
  trending  Json
  sentiment Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("social_monitors")
}

model Keyword {
  id               String      @id @default(cuid())
  keyword          String
  volume           Int
  difficulty       Int
  cpc              Float
  currentPosition  Int?        @map("current_position")
  previousPosition Int?        @map("previous_position")
  trend            Trend       @default(stable)
  intent           SearchIntent @default(informational)
  serpFeatures     String[]    @map("serp_features")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, keyword])
  @@map("keywords")
}

model AnalyticsData {
  id                String   @id @default(cuid())
  date              DateTime @db.Date
  traffic           Int
  organic           Int
  direct            Int
  referral          Int
  social            Int
  conversions       Int
  revenue           Float
  bounceRate        Float    @map("bounce_rate")
  avgSessionDuration Float   @map("avg_session_duration")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@map("analytics_data")
}

model Workflow {
  id          String          @id @default(cuid())
  name        String
  description String
  trigger     TriggerType     @default(manual)
  schedule    String?
  status      WorkflowStatus  @default(draft)
  lastRun     DateTime?       @map("last_run")
  nextRun     DateTime?       @map("next_run")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  agents WorkflowAgent[]
  runs   WorkflowRun[]

  @@map("workflows")
}

model WorkflowAgent {
  workflowId String @map("workflow_id")
  agentId    String @map("agent_id")

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  agent    Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([workflowId, agentId])
  @@map("workflow_agents")
}

model WorkflowRun {
  id          String           @id @default(cuid())
  status      WorkflowRunStatus @default(running)
  startedAt   DateTime         @default(now()) @map("started_at")
  completedAt DateTime?        @map("completed_at")
  results     Json?
  error       String?

  workflowId String   @map("workflow_id")
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@map("workflow_runs")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  actionUrl String?          @map("action_url")
  actionLabel String?        @map("action_label")
  createdAt DateTime         @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  provider  String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

enum UserRole {
  admin
  member
  viewer
}

enum Plan {
  free
  pro
  enterprise
}

enum ProjectStatus {
  active
  paused
  archived
}

enum AgentType {
  seo_audit
  geo_optimization
  content_writer
  reddit_monitor
  hackernews_monitor
  twitter_monitor
  linkedin_monitor
  competitor_analysis
  keyword_research
  backlink_builder
  technical_seo
  content_optimizer
}

enum AgentStatus {
  idle
  running
  completed
  error
  paused
}

enum Frequency {
  manual
  hourly
  daily
  weekly
}

enum AgentResultStatus {
  success
  warning
  error
}

enum ContentType {
  blog
  social
  email
  landing
  ad
}

enum ContentStatus {
  draft
  review
  approved
  published
}

enum Trend {
  up
  down
  stable
}

enum SearchIntent {
  informational
  navigational
  transactional
  commercial
}

enum TriggerType {
  manual
  scheduled
  event
}

enum WorkflowStatus {
  active
  paused
  draft
}

enum WorkflowRunStatus {
  running
  completed
  failed
}

enum NotificationType {
  success
  warning
  error
  info
}
